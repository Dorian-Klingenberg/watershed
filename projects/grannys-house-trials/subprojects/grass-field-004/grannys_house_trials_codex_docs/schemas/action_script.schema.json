{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grannys House Trials Action Script",
  "type": "object",
  "required": [
    "id",
    "name",
    "actions"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "tick",
          "action"
        ],
        "properties": {
          "tick": {
            "type": "integer",
            "minimum": 0
          },
          "action": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string"
              },
              "target": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object"
                  }
                ]
              },
              "parameters": {
                "type": "object"
              }
            }
          }
        }
      }
    }
  }
}
