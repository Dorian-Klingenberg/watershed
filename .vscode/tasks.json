{
  "version": "2.0.0",
  "tasks": [

    // ── CMake infrastructure ─────────────────────────────────────────────────
    {
      "label": "cmake: configure (debug)",
      "type": "shell",
      "command": "cmake --preset vs2026-debug",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "cmake: build all (debug)",
      "type": "shell",
      "command": "cmake --build --preset build-vs2026-debug",
      "options": { "cwd": "${workspaceFolder}" },
      "dependsOn": ["cmake: configure (debug)"],
      "dependsOrder": "sequence",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "cmake: build all (release)",
      "type": "shell",
      "command": "cmake --build --preset build-vs2026-release",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "cmake: test (debug)",
      "type": "shell",
      "command": "ctest --preset test-vs2026-debug",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },

